{
  "tasks": {
    "start": "deno run --allow-net --allow-read --allow-env --unstable-kv --watch src/main.ts",
    "test": "deno test --allow-all --unstable-kv"
  },
  "imports": {
    // ACTUALIZADO: Coincide con tu lockfile (v4)
    "hono": "npm:hono@^4.11.5", 
    "luxon": "npm:luxon@^3.4.0",
    "@std/assert": "jsr:@std/assert@1",
    "kysely": "npm:kysely@^0.27.2",
    "pg": "npm:pg@^8.11.3",
    "zod": "npm:zod@^3.22.4"
  },

  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": true,
    "semiColons": true,
    "proseWrap": "preserve"
  },

  "lint": {
    "include": ["src/"],
    "rules": {
      "tags": ["recommended"],
      "include": [
        "no-explicit-any",
        "eqeqeq",
        "require-await",
        "ban-untagged-todo",
        "no-unused-vars"
      ]
    }
  },
  
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "strictPropertyInitialization": true
  }
}